DATABASE_URL="postgresql://spaceflow:spaceflow@localhost:5432/spaceflow"
JWT_SECRET="change-this-to-a-long-random-secret-at-least-64-chars"
JWT_REFRESH_SECRET="change-this-to-another-long-random-secret-at-least-64-chars"
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:8080
# AI providers — Gemini is primary, OpenAI is fallback, rule-based if neither set
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
SEED_ADMIN_EMAIL="admin@spaceflow.local"
SEED_ADMIN_PASSWORD="your-secure-password"
